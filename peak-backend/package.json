{
  "name": "peak-backend",
  "version": "1.0.0",
  "description": "Production-ready Express backend prepared for Skyvern automation workflows.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "start:pm2": "pm2 start ecosystem.config.cjs --env production",
    "restart:pm2": "pm2 restart peak-backend",
    "stop:pm2": "pm2 stop peak-backend",
    "logs:pm2": "pm2 logs peak-backend",
    "delete:pm2": "pm2 delete peak-backend"
  },
  "keywords": [
    "express",
    "typescript",
    "skyvern",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.0",
    "otplib": "^13.4.0",
    "playwright": "^1.59.1",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/speakeasy": "^2.0.10",
    "nodemon": "^3.1.14",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
